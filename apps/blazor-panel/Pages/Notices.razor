@page "/notices"
@inject NoticeService NoticeSvc
@inject GmCommandService GmSvc

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="fas fa-bullhorn"></i> Notices</h1>
        <p class="page-subtitle">Server notices and announcements</p>
    </div>
</div>

<div class="card">
    <div class="card-title"><i class="fas fa-paper-plane"></i> Send Live Notice</div>
    <div style="display:flex;gap:10px;">
        <input class="form-control" placeholder="Type notice message..." @bind="liveNotice" />
        <button class="btn btn-primary" @onclick="SendLive"><i class="fas fa-paper-plane"></i> Send</button>
    </div>
    @if (liveSent) { <div class="alert alert-success" style="margin-top:10px;">Notice sent to all online players!</div> }
</div>

<div class="card">
    <div class="card-title"><i class="fas fa-list"></i> Saved Notices</div>
    <div style="display:flex;gap:10px;margin-bottom:15px;">
        <input class="form-control" placeholder="New notice..." @bind="newNotice" />
        <button class="btn btn-success" @onclick="AddNotice"><i class="fas fa-plus"></i> Add</button>
    </div>
    <div class="table-container">
        <table>
            <thead><tr><th>ID</th><th>Message</th><th>Active</th><th>Actions</th></tr></thead>
            <tbody>
                @foreach (var n in notices)
                {
                    <tr>
                        <td>@n.ID</td>
                        <td>@n.Message</td>
                        <td>
                            <label class="toggle-switch">
                                <input type="checkbox" checked="@n.IsActive" @onchange="(e) => Toggle(n.ID, (bool)(e.Value ?? false))" />
                                <span class="toggle-slider"></span>
                            </label>
                        </td>
                        <td><button class="btn btn-sm btn-danger" @onclick="() => Delete(n.ID)"><i class="fas fa-trash"></i></button></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    List<NoticeEntry> notices = new();
    string newNotice = "";
    string liveNotice = "";
    bool liveSent;

    protected override async Task OnInitializedAsync() { notices = await NoticeSvc.GetAll(); }

    async Task SendLive()
    {
        if (string.IsNullOrWhiteSpace(liveNotice)) return;
        await GmSvc.SendNotice(liveNotice);
        liveSent = true;
        liveNotice = "";
        StateHasChanged();
        await Task.Delay(3000);
        liveSent = false;
        StateHasChanged();
    }

    async Task AddNotice()
    {
        if (string.IsNullOrWhiteSpace(newNotice)) return;
        await NoticeSvc.Create(newNotice);
        notices = await NoticeSvc.GetAll();
        newNotice = "";
    }

    async Task Toggle(int id, bool active) { await NoticeSvc.ToggleActive(id, active); notices = await NoticeSvc.GetAll(); }
    async Task Delete(int id) { await NoticeSvc.Delete(id); notices = await NoticeSvc.GetAll(); }
}
