@page "/attendance"
@inject AttendanceService AttSvc

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="fas fa-calendar-check"></i> Attendance</h1>
        <p class="page-subtitle">Daily login reward configuration</p>
    </div>
    <button class="btn btn-primary" @onclick="ShowAdd"><i class="fas fa-plus"></i> Add Reward</button>
</div>

@if (msg != null) { <div class="alert alert-success">@msg</div> }

<div class="card">
    <div class="table-container">
        <table>
            <thead><tr><th>ID</th><th>Day</th><th>Item ID</th><th>CodeName</th><th>Count</th><th>Actions</th></tr></thead>
            <tbody>
                @foreach (var r in items)
                {
                    <tr>
                        <td>@r.ID</td>
                        <td><span class="badge">Day @r.DayCount</span></td>
                        <td>@r.ItemID</td>
                        <td>@r.ItemCodeName128</td>
                        <td>@r.ItemCount</td>
                        <td>
                            <button class="btn btn-sm btn-primary" @onclick="() => Edit(r)"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-sm btn-danger" @onclick="() => Delete(r.ID)"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (showForm)
{
    <div class="card">
        <div class="card-title">@(editing != null ? "Edit" : "Add") Attendance Reward</div>
        <div class="form-grid">
            <div class="form-group"><label class="form-label">Day Number</label><input class="form-control" type="number" @bind="form.DayCount" /></div>
            <div class="form-group"><label class="form-label">Item ID</label><input class="form-control" type="number" @bind="form.ItemID" /></div>
            <div class="form-group"><label class="form-label">Item CodeName</label><input class="form-control" @bind="form.ItemCodeName128" /></div>
            <div class="form-group"><label class="form-label">Item Count</label><input class="form-control" type="number" @bind="form.ItemCount" /></div>
        </div>
        <div style="display:flex;gap:10px;margin-top:10px;">
            <button class="btn btn-success" @onclick="Save"><i class="fas fa-save"></i> Save</button>
            <button class="btn btn-danger" @onclick="() => showForm = false"><i class="fas fa-times"></i> Cancel</button>
        </div>
    </div>
}

@code {
    List<RefAttendanceReward> items = new();
    RefAttendanceReward form = new();
    RefAttendanceReward? editing;
    bool showForm = false;
    string? msg;

    protected override async Task OnInitializedAsync() { items = await AttSvc.GetAll(); }
    void ShowAdd() { form = new(); editing = null; showForm = true; }
    void Edit(RefAttendanceReward r) { form = new() { ID = r.ID, ItemID = r.ItemID, ItemCodeName128 = r.ItemCodeName128, ItemCount = r.ItemCount, DayCount = r.DayCount }; editing = r; showForm = true; }

    async Task Save()
    {
        if (editing != null) await AttSvc.Update(form);
        else await AttSvc.Create(form);
        items = await AttSvc.GetAll();
        showForm = false;
        msg = editing != null ? "Updated!" : "Created!";
    }

    async Task Delete(int id)
    {
        await AttSvc.Delete(id);
        items = await AttSvc.GetAll();
        msg = "Deleted!";
    }
}
