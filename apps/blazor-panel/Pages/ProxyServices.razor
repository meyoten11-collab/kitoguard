@page "/proxy"
@inject ProxyService ProxySvc

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="fas fa-network-wired"></i> Proxy Services</h1>
        <p class="page-subtitle">Manage filter proxy service endpoints</p>
    </div>
    <button class="btn btn-primary" @onclick="ShowAdd"><i class="fas fa-plus"></i> Add Service</button>
</div>

@if (msg != null) { <div class="alert alert-success"><i class="fas fa-check-circle"></i> @msg</div> }

<div class="card">
    <div class="table-container">
        <table>
            <thead><tr><th>ID</th><th>Name</th><th>Type</th><th>Remote</th><th>Bind</th><th>ByteLimit</th><th>AutoStart</th><th>Actions</th></tr></thead>
            <tbody>
                @foreach (var s in services)
                {
                    <tr>
                        <td>@s.ServiceId</td>
                        <td><strong>@s.Name</strong></td>
                        <td>@s.ServerType</td>
                        <td>@s.RemoteIP:@s.RemotePort</td>
                        <td>@s.BindIP:@s.BindPort</td>
                        <td>@s.ByteLimitation</td>
                        <td>
                            <label class="toggle-switch">
                                <input type="checkbox" checked="@s.AutoStart" disabled />
                                <span class="toggle-slider"></span>
                            </label>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-primary" @onclick="() => EditProxy(s)"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteProxy(s.ServiceId)"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (showForm)
{
    <div class="card">
        <div class="card-title">@(editing != null ? "Edit" : "Add") Proxy Service</div>
        <div class="form-grid">
            <div class="form-group"><label class="form-label">Name</label><input class="form-control" @bind="form.Name" /></div>
            <div class="form-group"><label class="form-label">Server Type</label><input class="form-control" type="number" @bind="form.ServerType" /></div>
            <div class="form-group"><label class="form-label">Remote IP</label><input class="form-control" @bind="form.RemoteIP" /></div>
            <div class="form-group"><label class="form-label">Remote Port</label><input class="form-control" type="number" @bind="form.RemotePort" /></div>
            <div class="form-group"><label class="form-label">Bind IP</label><input class="form-control" @bind="form.BindIP" /></div>
            <div class="form-group"><label class="form-label">Bind Port</label><input class="form-control" type="number" @bind="form.BindPort" /></div>
            <div class="form-group"><label class="form-label">Byte Limit</label><input class="form-control" type="number" @bind="form.ByteLimitation" /></div>
            <div class="form-group">
                <label class="form-label">Auto Start</label>
                <label class="toggle-switch"><input type="checkbox" @bind="form.AutoStart" /><span class="toggle-slider"></span></label>
            </div>
        </div>
        <div style="display:flex;gap:10px;margin-top:10px;">
            <button class="btn btn-success" @onclick="SaveProxy"><i class="fas fa-save"></i> Save</button>
            <button class="btn btn-danger" @onclick="() => showForm = false"><i class="fas fa-times"></i> Cancel</button>
        </div>
    </div>
}

@code {
    List<ProxyServiceModel> services = new();
    ProxyServiceModel form = new();
    ProxyServiceModel? editing;
    bool showForm = false;
    string? msg;

    protected override async Task OnInitializedAsync() { services = await ProxySvc.GetAll(); }

    void ShowAdd() { form = new(); editing = null; showForm = true; }
    void EditProxy(ProxyServiceModel s) { form = new() { ServiceId = s.ServiceId, Name = s.Name, ServerType = s.ServerType, RemoteIP = s.RemoteIP, RemotePort = s.RemotePort, BindIP = s.BindIP, BindPort = s.BindPort, ByteLimitation = s.ByteLimitation, AutoStart = s.AutoStart }; editing = s; showForm = true; }

    async Task SaveProxy()
    {
        if (editing != null) await ProxySvc.Update(form);
        else await ProxySvc.Create(form);
        services = await ProxySvc.GetAll();
        showForm = false;
        msg = editing != null ? "Updated!" : "Created!";
    }

    async Task DeleteProxy(int id)
    {
        await ProxySvc.Delete(id);
        services = await ProxySvc.GetAll();
        msg = "Deleted!";
    }
}
